# Moodle 5.2 Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# MOODLE CONFIGURATION
# ============================================
# IMPORTANT: MOODLE_ROOT must be a valid URL (not 0.0.0.0)
# For local development: 127.0.0.1 or localhost
# For production: your domain name (e.g., moodle.yourdomain.com)
MOODLE_VERSION=502
MOODLE_LANG=fr
MOODLE_ROOT=127.0.0.1
MOODLE_DBTYPE=pgsql
MOODLE_DBHOST=postgres
MOODLE_DBNAME=moodle
MOODLE_DBUSER=moodleadmin
MOODLE_DBPASS=CHANGE_ME
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=CHANGE_ME
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_SUPPORT_EMAIL=support@example.com
MOODLE_FULLNAME=Moodle
MOODLE_SHORTNAME=Moodle

# ============================================
# DOCKER PORT CONFIGURATION
# ============================================
# Bind addresses: 127.0.0.1 = localhost only, 0.0.0.0 = all interfaces
# For security, use 127.0.0.1 for databases and admin tools

# Moodle web server
MOODLE_HOST=0.0.0.0
MOODLE_PORT=80

# PostgreSQL database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# PGAdmin web interface
PGADMIN_HOST=127.0.0.1
PGADMIN_PORT=8081

# Redis cache server
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# RedisInsight web interface
REDISINSIGHT_HOST=127.0.0.1
REDISINSIGHT_PORT=5540

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_VERSION=18.4
POSTGRES_DB=moodle
POSTGRES_USER=moodleadmin
POSTGRES_PASSWORD=CHANGE_ME
ALLOW_EMPTY_PASSWORD=false
PGDATA=/var/lib/postgresql/data/pgdata

# ============================================
# PGADMIN CONFIGURATION
# ============================================
ADMIN_EMAIL=admin@pgadmin.com
ADMIN_PASSWORD=CHANGE_ME

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_VERSION=8.8.0

# ============================================
# REDISINSIGHT CONFIGURATION
# ============================================
REDISINSIGHT_VERSION=3.6
